{
  "name": "wxstation-backend",
  "private": true,
  "scripts": {
    "venv": "python -m venv .venv",
    "install": ".venv\\Scripts\\python.exe -m pip install -r requirements.txt",
    "test": ".venv\\Scripts\\python.exe -m pytest",
    "start": ".venv\\Scripts\\python.exe -m uvicorn main:app --host 0.0.0.0 --port 8001",
    "dev": ".venv\\Scripts\\python.exe -m uvicorn main:app --reload --host 0.0.0.0 --port 8001"
  }
}